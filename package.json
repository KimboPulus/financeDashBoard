{
  "name": "finance-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Personal expense dashboard with React and FastAPI.",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev --workspace client\"",
    "dev:api": "server\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --app-dir server --reload --host 127.0.0.1 --port 4000",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace client",
    "test:client": "npm run test --workspace client",
    "test:api": "server\\.venv\\Scripts\\python.exe -m pytest server/tests",
    "test": "npm run test:client && npm run test:api",
    "start:api": "server\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --app-dir server --host 127.0.0.1 --port 4000"
  },
  "workspaces": [
    "client"
  ],
  "devDependencies": {
    "concurrently": "9.2.0"
  }
}
